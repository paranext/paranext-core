{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": ".claude/scripts/statusline.sh",
    "padding": 2
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "Skill(papi-client)",
      "Skill(log-inspector)",
      "Skill(app-runner)",
      "Skill(test-runner)",
      "Skill(visual-verification)",
      "Skill(keybindings-help)",
      "mcp__ide__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(mkfs:*)",
      "Bash(chmod -R 777 /)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(chmod -R:*)",
      "Bash(chown -R:*)",
      "Bash(sudo:*)",
      "Bash(eval:*)",
      "Bash(npm publish:*)"
    ]
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "Generated with [Claude Code](https://claude.com/claude-code)"
  },
  "autoUpdatesChannel": "stable",
  "cleanupPeriodDays": 14,
  "respectGitignore": true
}
