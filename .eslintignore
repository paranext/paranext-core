# Please keep this file in sync with .prettierignore, .prettierignorerun and .stylelintignore

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed

# Coverage directory used by tools like istanbul
coverage
.eslintcache

# Dependency directory
# https://www.npmjs.org/doc/misc/npm-faq.html#should-i-check-my-node_modules-folder-into-git
node_modules

# OSX
.DS_Store

release/app/buildInfo.json
release/app/dist
release/build
.erb/dll
dev-appdata

.idea
npm-debug.log.*
*.css.d.ts
*.sass.d.ts
*.scss.d.ts

# Packager output
dist

# eslint ignores hidden directories by default:
# https://github.com/eslint/eslint/issues/8429
!.erb
!.storybook

# directories that have separate eslint project
extensions
lib/browserslist-config-detect-electron
lib/eslint-plugin-paranext
lib/papi-dts
lib/platform-bible-react
lib/platform-bible-utils

# generated files
package-lock.json
bin
obj
storybook-static
# Autogenerated runtime-verifier specs (DO NOT EDIT BY HAND; byte-deterministic,
# regenerated from integration-plan.json). Lint-ignored because the generator
# emits its own canonical style that intentionally differs from repo ESLint rules.
e2e-tests/tests/**/generated/

# yalc
.yalc
yalc.lock

# Local dev packages checked out for linking during CI or local development
dev-packages/

# Playwright test output
e2e-tests/test-results
e2e-tests/playwright-report

# Embedded Claude Code profile (vendored from ai-prompts; exempt from repo format/lint)
.claude
.context
CLAUDE.md
