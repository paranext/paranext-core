{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "lib": ["dom", "es2023"],
    "strict": true,
    "sourceMap": true,
    "paths": {
      "@assets/*": ["./assets/*"],
      "@client/*": ["./src/client/*"],
      "@extension-host/*": ["./src/extension-host/*"],
      "@main/*": ["./src/main/*"],
      "@node/*": ["./src/node/*"],
      "@renderer/*": ["./src/renderer/*"],
      "@shared/*": ["./src/shared/*"],
      "vite": ["./src/@types/shims-vite.d.ts"]
    },
    "experimentalDecorators": true,
    "typeRoots": [
      // Include default type declarations
      "./node_modules/@types",
      // Include extensions' type declarations
      "./extensions/src",
      // Include additions and overrides
      "src/@types"
    ],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "incremental": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "outDir": ".erb/dll"
  },
  "include": ["src", "assets", "!**/*.test.{ts,tsx}"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "release/build",
    "release/app/dist",
    ".erb/dll",
    "extensions",
    "lib/platform-bible-react",
    "lib/platform-bible-utils",
    "lib/papi-dts",
    "lib/browserslist-config-detect-electron"
  ],
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
