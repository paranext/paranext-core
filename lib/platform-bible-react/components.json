{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-nova",
  "rsc": false,
  "tsx": true,
  "rtl": true,
  "tailwind": {
    "config": "",
    "css": "src/index.css",
    "baseColor": "olive",
    "cssVariables": true,
    "prefix": "tw"
  },
  "iconLibrary": "tabler",
  "aliases": {
    "components": "@/components/shadcn-ui",
    "utils": "@/utils/shadcn-ui/utils",
    "ui": "@/components/shadcn-ui",
    "lib": "@/utils/shadcn-ui",
    "hooks": "@/hooks/shadcn-ui"
  },
  "menuColor": "default-translucent",
  "menuAccent": "subtle",
  "registries": {
    "@shadcn-editor": "https://shadcn-editor.vercel.app/r/{name}.json"
  }
}
