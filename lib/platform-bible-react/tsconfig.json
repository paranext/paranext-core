{
  "extends": "../../tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    // Running npm i removes packages that are in common between the current directory's
    // node_modules and any below. Without typeRoots specified like this, TypeScript climbs
    // directories looking for node_modules/@types folders by default.
    // We needed to remove react from here below because having two copies was causing problems in
    // the jest tests. But we need the types in both places.
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types", "./src/types"],
    // `vite-env` (css imports) and `experimental-papi-shim` (declares `@papi/frontend/react`)
    // are listed here because dts-bundle-generator replaces `include` with a single entry file
    // and would otherwise drop these ambient ./src/types/*.d.ts.
    "types": ["node", "jest", "vite-env", "react-19-compat", "experimental-papi-shim"],
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "forceConsistentCasingInFileNames": true,
    "incremental": false,
    "isolatedModules": true,
    "noEmit": true,
    "noImplicitReturns": true,
    "skipLibCheck": false,
    "useDefineForClassFields": true,
    "outDir": "",
    "paths": {
      "@/*": ["./src/*"],
      // Virtual alias for the narrow project-data-provider shim, needed only because the ambient
      // `@papi/frontend/react` declaration in experimental-papi-shim.d.ts cannot use a relative
      // import (TS2439). Deliberately NOT named `platform-scripture`: this package must never
      // resolve that extension's module, so real imports of it should fail loudly.
      "@shims/text-connection-settings-pdp": ["./src/types/text-connection-settings-pdp.shim.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/components/shadcn-ui-old/*"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
