{
  // Type-check gate for the startup-waterfall parser + CLI under .erb/scripts, which the root
  // tsconfig's `include` ("src", "assets") leaves out. Without this, a type error in the parser or
  // CLI would keep CI green and surface only at manual runtime. Scoped to these files (not all of
  // .erb/scripts) because the older scripts there carry pre-existing type issues from their own
  // heavy deps and are out of scope for this gate. The colocated *.util.test.ts is not listed for
  // the same reason the root config excludes all `*.test.ts`: test files rely on Vitest's runtime
  // (which exercises this parser via its own 9 tests), not tsc. Referenced by `npm run typecheck`
  // via `typecheck:erb`. Emits nothing - it is purely a gate.
  //
  // `types` is pinned to Node only so the root's `typeRoots` (which includes ./extensions/src)
  // doesn't drag extension .d.ts augmentations of papi-shared-types into a compile that doesn't
  // include src to define their base members.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false,
    "types": ["node"]
  },
  "include": [".erb/scripts/startup-waterfall.ts", ".erb/scripts/startup-waterfall.util.ts"],
  "exclude": ["node_modules"]
}
